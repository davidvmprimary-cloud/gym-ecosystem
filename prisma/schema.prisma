generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  name          String?
  avatarUrl     String?
  weight        Float?    // kg
  height        Float?    // cm
  birthDate     DateTime?
  defaultImprovementTarget Float @default(2.5) // porcentaje global
  createdAt     DateTime  @default(now())

  splits        Split[]
  sessions      Session[]
  nutritionLogs NutritionLog[]
  personalRecords PersonalRecord[]
  bodyWeights   BodyWeightLog[]
}

model Split {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  name      String     // "Push", "Pull", "Legs"
  order     Int        // 1, 2, 3 — define la secuencia del ciclo
  user      User       @relation(fields: [userId], references: [id])
  exercises Exercise[]
  sessions  Session[]
}

model Exercise {
  id                      String   @id @default(uuid()) @db.Uuid
  splitId                 String   @db.Uuid
  name                    String
  order                   Int
  improvementTarget       Float?   // override personal del ejercicio, null = hereda del user
  split                   Split    @relation(fields: [splitId], references: [id])
  sets                    Set[]
  personalRecords         PersonalRecord[]
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  splitId   String   @db.Uuid
  date      DateTime @default(now())
  notes     String?
  totalVolume     Float?          // kg×reps sumado de todos los sets
  durationMinutes Int?
  perceivedEffort Int?            // 1-10 RPE subjetivo
  progressPct     Float?          // % vs sesión anterior del mismo split
  user      User     @relation(fields: [userId], references: [id])
  split     Split    @relation(fields: [splitId], references: [id])
  sets      Set[]
}

model Set {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @db.Uuid
  exerciseId  String   @db.Uuid
  setNumber   Int
  weightKg    Float
  reps        Int
  volume           Float   @default(0)
  isPersonalRecord Boolean @default(false)
  session     Session  @relation(fields: [sessionId], references: [id])
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
}

model NutritionLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  date         DateTime @default(now())
  calories     Int
  proteinG     Float
  carbsG       Float
  fatG         Float
  notes        String?
  user         User     @relation(fields: [userId], references: [id])
}

model PersonalRecord {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  exerciseId  String   @db.Uuid
  recordType  String   // "volume" | "weight" | "reps" | "estimated1rm"
  value       Float
  setId       String?  @db.Uuid
  sessionId   String   @db.Uuid
  achievedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
}

model BodyWeightLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  weightKg  Float
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
